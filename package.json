{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-go-multi-auth",
  "version": "0.1.2",
  "description": "Multi-account API key rotation for OpenCode Go subscription",
  "type": "module",
  "bin": {
    "go-multi-auth": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun build ./src/index.ts --outfile dist/index.js --format esm --target node && bun build ./src/cli.ts --outfile dist/cli.js --format esm --target node",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "multi-account",
    "auth",
    "plugin"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.2",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
