{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-go-multi-auth",
  "version": "0.1.0",
  "description": "Multi-account API key rotation for OpenCode Go subscription",
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outfile dist/index.mjs --format esm --target node",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "multi-account",
    "auth",
    "plugin"
  ],
  "license": "MIT",
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.2",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "typescript": "^5.8.0"
  }
}
